# =============================================================================
#  Token Config
# =============================================================================
TOKEN_NAME="Example Stablecoin"
TOKEN_SYMBOL=EXUSD
TOKEN_DECIMALS=18

# =============================================================================
#  Final owner of the token after minting completes
# =============================================================================
OWNER_ADDRESS=0x1111111111111111111111111111111111111111

# =============================================================================
#  Recipients
#  Set RECIPIENT_COUNT, then define RECIPIENT_<n>_ADDRESS / RECIPIENT_<n>_AMOUNT
# =============================================================================
RECIPIENT_COUNT=2
RECIPIENT_1_ADDRESS=0x2222222222222222222222222222222222222222
RECIPIENT_1_AMOUNT=1000000000000000000000
RECIPIENT_2_ADDRESS=0x3333333333333333333333333333333333333333
RECIPIENT_2_AMOUNT=500000000000000000000

# =============================================================================
#  Deployer
# =============================================================================
# Private key of the deployer/broadcaster account (required for --broadcast)
PRIVATE_KEY=0x...

# =============================================================================
#  RPC URLs (set the ones you need)
# =============================================================================
# Anvil defaults to http://127.0.0.1:8545 if unset
ANVIL_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
