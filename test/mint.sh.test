#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

cat > "$TMPDIR/forge" <<'MOCK'
#!/usr/bin/env bash
echo "mock forge $*"
MOCK
chmod +x "$TMPDIR/forge"

assert_contains() {
  local haystack="$1"
  local needle="$2"
  if [[ "$haystack" != *"$needle"* ]]; then
    echo "Expected output to contain: $needle" >&2
    echo "Actual output:" >&2
    echo "$haystack" >&2
    exit 1
  fi
}

output="$(PATH="$TMPDIR:$PATH" "$REPO_ROOT/mint.sh" --chain anvil)"
assert_contains "$output" "Chain alias: anvil"
assert_contains "$output" "Token name: Example Stablecoin"
assert_contains "$output" "Token symbol: EXUSD"
assert_contains "$output" "Token decimals: 18"
assert_contains "$output" "Final owner: address(0)"
assert_contains "$output" "Recipient count: 0"
assert_contains "$output" "Total mint amount: 0"
assert_contains "$output" "Mode: simulation"
assert_contains "$output" "mock forge script script/DeployAndDistribute.s.sol:DeployAndDistribute --rpc-url http://127.0.0.1:8545"

TEST_REPO="$TMPDIR/multiline-repo"
mkdir -p "$TEST_REPO/config" "$TEST_REPO/script"
cp "$REPO_ROOT/mint.sh" "$TEST_REPO/mint.sh"
cp "$REPO_ROOT/config/chains.sh" "$TEST_REPO/config/chains.sh"
chmod +x "$TEST_REPO/mint.sh"

cat > "$TEST_REPO/script/DeployAndDistribute.s.sol" <<'SOL'
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.25;

struct TokenConfig {
    string name;
    string symbol;
    uint8 decimals;
    address finalOwner;
}

struct Recipient {
    address to;
    uint256 amount;
}

contract DeployAndDistribute {
    function _tokenConfig() internal pure returns (TokenConfig memory config) {
        config = TokenConfig({
            name: "Multiline Stablecoin",
            symbol: "MLS",
            decimals: 6,
            finalOwner:
                0x000000000000000000000000000000000000dEaD
        });
    }

    function _recipients() internal pure returns (Recipient[] memory recipients) {
        recipients = new Recipient[](2);
        recipients[0] = Recipient({
            to: 0x0000000000000000000000000000000000000001,
            amount:
                10 ether
        });
        recipients[1] = Recipient({
            to: 0x0000000000000000000000000000000000000002,
            amount:
                25
        });
    }
}
SOL

multiline_output="$(PATH="$TMPDIR:$PATH" "$TEST_REPO/mint.sh" --chain anvil)"
assert_contains "$multiline_output" "Token name: Multiline Stablecoin"
assert_contains "$multiline_output" "Token symbol: MLS"
assert_contains "$multiline_output" "Token decimals: 6"
assert_contains "$multiline_output" "Final owner: 0x000000000000000000000000000000000000dEaD"
assert_contains "$multiline_output" "Recipient count: 2"
assert_contains "$multiline_output" "Total mint amount: 10000000000000000025"

echo "mint.sh preflight test passed"
